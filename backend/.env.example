# CacheFlow Environment Variables

# ── Server ──────────────────────────────────────────────
PORT=5000

# ── MongoDB URI ──────────────────────────────────────────
# Option A: Local MongoDB
MONGODB_URI=mongodb://localhost:27017/cacheflow

# Option B: MongoDB Atlas (comment out A and use this)
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/cacheflow

# ── Redis (optional L2 cache) ─────────────────────────────
# If not running Redis, the app falls back to L1 LRU cache only
REDIS_URL=redis://localhost:6379
